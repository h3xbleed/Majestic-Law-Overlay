{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Majestic Law",
  "version": "0.1.0",
  "identifier": "ru.majesticlaw.overlay",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Majestic Law",
        "width": 780,
        "height": 680,
        "minWidth": 560,
        "minHeight": 420,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
